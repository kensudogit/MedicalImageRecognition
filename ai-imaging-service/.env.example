# 医療画像AIサービス環境変数
AI_DEFAULT_PROVIDER=inhouse
AI_USE_LOCAL_CV=true
AI_FORCE_LOCAL_CV=false
AI_ENABLE_MOCK_INFERENCE=false
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=3600
AI_CACHE_MAX_ENTRIES=128
AI_MAX_CONCURRENT_ANALYSES=4
AI_PREVIEW_MAX_SIZE=1024
AI_UPLOAD_DIR=./uploads/ai-imaging
AI_PREVIEW_DIR=./uploads/ai-imaging/previews

# 自社AIモデル（未設定時はローカルCV）
AI_INHOUSE_MODEL_URL=
AI_INHOUSE_API_KEY=

# OpenAI Vision（未設定時はローカルCVへフォールバック）
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OPENAI_ORGANIZATION=
AI_OPENAI_MAX_TOKENS=1200
AI_OPENAI_TIMEOUT_SECONDS=90

# AWS SageMaker
AI_AWS_REGION=ap-northeast-1
AI_SAGEMAKER_ENDPOINT_NAME=
AI_AWS_ACCESS_KEY_ID=
AI_AWS_SECRET_ACCESS_KEY=

# Azure AI
AI_AZURE_AI_ENDPOINT=
AI_AZURE_AI_KEY=
AI_AZURE_AI_MODEL=medical-imaging

# Google Cloud
AI_GCP_PROJECT_ID=
AI_GCP_LOCATION=asia-northeast1
AI_GCP_ENDPOINT_ID=

# 外部医療AI API
AI_EXTERNAL_MEDICAL_AI_URL=
AI_EXTERNAL_MEDICAL_AI_KEY=
